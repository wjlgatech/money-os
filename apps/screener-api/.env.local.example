# Database (Supabase PostgreSQL — required for production, optional for dev)
DATABASE_URL=postgresql://user:pass@host:5432/screener

# Cache (Upstash Redis — optional, falls back to in-memory)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Market Data (Alpaca — required for live data, optional for dev)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://data.alpaca.markets

# Alpaca Trading (paper or live — required for broker execution)
ALPACA_TRADING_KEY=your-paper-trading-key
ALPACA_TRADING_SECRET=your-paper-trading-secret
ALPACA_PAPER_MODE=true

# Auth (simple bearer token for API access)
SCREENER_API_TOKEN=your-secret-token-here

# Vercel Cron (validates cron requests in production)
CRON_SECRET=your-cron-secret-here
