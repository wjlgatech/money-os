# Copy this file to .env and fill in your values.
# Real keys live in ~/.secrets — sourced automatically in every terminal.
# This file documents which keys THIS project needs.

ANTHROPIC_API_KEY=           # Required — Claude API (screener-api AI coaching)
DATABASE_URL=                # Required — PostgreSQL connection for screener-api
OPENAI_API_KEY=              # Optional — OpenAI CLI client (scripts/cli)
